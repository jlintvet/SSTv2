import json

with open("SST_2026-03-15.json") as f:
    data = json.load(f)

# Land = mask != 1, coarsened to 0.05° bins
BIN = 0.05
land_set = set()
for r in data["rows"]:
    if r["mask"] != 1:  # not ocean
        lat = round(round(r["lat"] / BIN) * BIN, 2)
        lon = round(round(r["lon"] / BIN) * BIN, 2)
        land_set.add((lat, lon))

out = {"points": [{"lat": lat, "lon": lon} for lat, lon in sorted(land_set)]}
with open("landmask.json", "w") as f:
    json.dump(out, f)

print(f"Land points: {len(out['points'])}")
